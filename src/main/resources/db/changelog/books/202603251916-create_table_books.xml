<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="https://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="https://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">
  <changeSet id="1774448007258-1" author="mavluda">
    <createTable tableName="books">
      <column autoIncrement="true" name="id" type="BIGINT">
        <constraints nullable="false" primaryKey="true" primaryKeyName="pk_books"/>
      </column>
      <column name="created_at" type="DATETIME"/>
      <column name="created_by" type="BIGINT"/>
      <column name="updated_at" type="DATETIME"/>
      <column name="updated_by" type="BIGINT"/>
      <column name="deleted_at" type="DATETIME"/>
      <column name="deleted_by" type="BIGINT"/>
      <column name="name" type="VARCHAR(255)"/>
      <column name="year" type="INT"/>
      <column name="purchase_date" type="DATE"/>
      <column name="start_reading_date" type="DATE"/>
      <column name="finish_reading_date" type="DATE"/>
      <column name="price" type="DOUBLE"/>
      <column name="note" type="VARCHAR(2000)"/>
      <column name="publisher" type="VARCHAR(255)"/>
      <column name="language" type="VARCHAR(255)"/>
      <column name="pages" type="INT"/>
    </createTable>
  </changeSet>

</databaseChangeLog>